{
  "name": "review-flow",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "antd:migrate": "antd migrate",
    "antd:mcp": "antd mcp",
    "antd:guard": "bash ./scripts/check-antd-compat.sh",
    "check:antd": "pnpm antd:guard && pnpm check",
    "generate:api": "orval",
    "check": "pnpm lint && pnpm typecheck",
    "prepare": "husky",
    "openapi:generate": "orval"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@tanstack/react-query": "^5.99.0",
    "antd": "^6.3.6",
    "axios": "^1.15.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@ant-design/cli": "^6.3.7",
    "@biomejs/biome": "^2.4.12",
    "@oxc-parser/binding-darwin-arm64": "^0.129.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "orval": "^8.9.1",
    "typescript": "^5"
  }
}
